# ZidStore API Environment Variables
# Copy this file to .env and fill in your values

# Server Configuration
PORT=3000
NODE_ENV=production
DOMAIN=zds.web.id

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_ADMIN_ID=your_telegram_user_id_here

# Database
DB_PATH=./data/zidstore.db

# API Key Generator
KEY_LENGTH=20
KEY_PREFIX=zs

# Script Download
SCRIPT_PATH=./resources/zidstoretunnel
SCRIPT_BRANCH=main
SCRIPT_REPO=zidnyzd/ScriptTunnel
